---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
}

const {
  title = "Defensa del Deudor | Ley de Segunda Oportunidad en España",
  description = "Comprueba en 30 segundos si cumples los requisitos legales para cancelar hasta el 100% de tus deudas en España conforme al Real Decreto-ley 1/2015.",
  canonicalUrl = "https://defensadeudor.es/"
} = Astro.props;

const jsonLdSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LegalService",
      "@id": "https://defensadeudor.es/#service",
      "name": "Defensa del Deudor",
      "description": description,
      "url": canonicalUrl,
      "areaServed": "ES",
      "knowsAbout": ["Ley de Segunda Oportunidad", "Real Decreto-ley 1/2015", "Cancelación de Deudas", "Paralización de Embargos"],
      "priceRange": "Gratis evaluación inicial"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué es la Ley de Segunda Oportunidad y a quién beneficia?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La Ley de Segunda Oportunidad (Real Decreto-ley 1/2015) es un mecanismo legal en España que permite a particulares y autónomos sobreendeudados o en situación de insolvencia cancelar hasta el 100% de sus deudas no impagables y empezar de cero sin embargos."
          }
        },
        {
          "@type": "Question",
          "name": "¿Es posible paralizar embargos de nómina y vivienda de inmediato?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Una vez iniciado el procedimiento legal conforme a la Ley de Segunda Oportunidad, la ley exige la congelación e interrupción inmediata de todas las ejecuciones de embargo, así como la parada del cobro de intereses y llamadas de acoso de cobradores."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué tipo de deudas se pueden cancelar?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Se pueden cancelar préstamos personales, tarjetas de crédito, microcréditos, deudas con entidades bancarias, financieras y parte de las deudas con Administraciones Públicas (Hacienda y Seguridad Social) conforme a las sentencias del Tribunal Supremo."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta la evaluación inicial de mi caso?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La evaluación inicial de viabilidad es 100% gratuita y sin compromiso. Analizamos tu situación de endeudamiento en menos de 24-48 horas y un abogado especialista en tu provincia te explicará de forma clara tus opciones legales."
          }
        }
      ]
    }
  ]
};
---

<!usr/bin/env html>
<html lang="es" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD Structured Data for Google Rich Snippets -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdSchema)} />

    <!-- Meta Pixel Code -->
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '1939634553277579');
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=1939634553277579&ev=PageView&noscript=1" /></noscript>
    <!-- End Meta Pixel Code -->

    <!-- Google Fonts Inter & Plus Jakarta Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet">
  </head>
  <body class="bg-slate-950 text-slate-100 font-sans min-h-screen flex flex-col justify-between selection:bg-emerald-500/20 selection:text-emerald-300">
    <slot />
  </body>
</html>
