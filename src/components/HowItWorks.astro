---
---

<section class="py-16 relative">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <span class="text-xs font-bold tracking-widest text-slate-400 uppercase bg-slate-900 border border-slate-800 px-3 py-1 rounded-md mb-3 inline-block">
        CÓMO FUNCIONA
      </span>
      <h2 class="font-display text-2xl sm:text-4xl font-extrabold text-white tracking-tight">
        Tres pasos. Cero papeleo inicial.
      </h2>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Card 01 -->
      <div class="glass-card p-6 rounded-2xl border border-slate-800/80 hover:border-emerald-500/40 hover:shadow-xl hover:shadow-emerald-500/5 transition-all duration-300 flex flex-col justify-between relative group hover:-translate-y-1">
        <div>
          <div class="flex items-center justify-between mb-6">
            <div class="w-12 h-12 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center text-emerald-400 group-hover:border-emerald-500/50 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 stroke-[1.75]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>
                <path d="M15 2H9a1 1 0 0 0-1 1v2a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1Z"/>
                <path d="M9 12h6"/>
                <path d="M9 16h6"/>
              </svg>
            </div>
            <span class="font-mono text-xs font-bold text-slate-400 bg-slate-900 px-2.5 py-1 rounded-md border border-slate-800">
              01
            </span>
          </div>

          <h3 class="text-lg font-bold text-slate-100 mb-2">
            Evaluación Inicial
          </h3>
          <p class="text-sm text-slate-400 leading-relaxed">
            Analizamos tus respuestas en tiempo real para verificar la viabilidad jurídica de tu caso.
          </p>
        </div>
      </div>

      <!-- Card 02 -->
      <div class="glass-card p-6 rounded-2xl border border-slate-800/80 hover:border-emerald-500/40 hover:shadow-xl hover:shadow-emerald-500/5 transition-all duration-300 flex flex-col justify-between relative group hover:-translate-y-1">
        <div>
          <div class="flex items-center justify-between mb-6">
            <div class="w-12 h-12 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center text-emerald-400 group-hover:border-emerald-500/50 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 stroke-[1.75]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <span class="font-mono text-xs font-bold text-slate-400 bg-slate-900 px-2.5 py-1 rounded-md border border-slate-800">
              02
            </span>
          </div>

          <h3 class="text-lg font-bold text-slate-100 mb-2">
            Llamada Especialista
          </h3>
          <p class="text-sm text-slate-400 leading-relaxed">
            Si eres apto, asignamos tu caso de forma confidencial a nuestro bufete colaborador en tu provincia.
          </p>
        </div>
      </div>

      <!-- Card 03 -->
      <div class="glass-card p-6 rounded-2xl border border-slate-800/80 hover:border-emerald-500/40 hover:shadow-xl hover:shadow-emerald-500/5 transition-all duration-300 flex flex-col justify-between relative group hover:-translate-y-1">
        <div>
          <div class="flex items-center justify-between mb-6">
            <div class="w-12 h-12 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center text-emerald-400 group-hover:border-emerald-500/50 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 stroke-[1.75]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/>
                <path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/>
                <path d="M7 21h10"/>
                <path d="M12 3v18"/>
                <path d="M3 7h18"/>
              </svg>
            </div>
            <span class="font-mono text-xs font-bold text-slate-400 bg-slate-900 px-2.5 py-1 rounded-md border border-slate-800">
              03
            </span>
          </div>

          <h3 class="text-lg font-bold text-slate-100 mb-2">
            Estudio Gratuito
          </h3>
          <p class="text-sm text-slate-400 leading-relaxed">
            Un abogado especializado te llamará en 24-48h para explicarte cómo paralizar embargos y borrar tus deudas.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
