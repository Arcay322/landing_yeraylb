---
import siteContent from '../data/site-content.json';
const { 
  badge, 
  titlePrefix, 
  titleHighlightSeconds, 
  titleMiddle, 
  titleHighlightPercentage, 
  titleSuffix, 
  subtitle, 
  ctaText, 
  trustBadges 
} = siteContent.hero;
---

<section class="relative pt-12 pb-16 md:pt-20 md:pb-24 overflow-hidden">
  <!-- Glowing background elements -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none"></div>
  
  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center relative z-10">
    <!-- Green Dot Badge -->
    <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full bg-slate-900/90 border border-slate-800 text-xs sm:text-sm font-medium text-slate-300 mb-8 shadow-inner shadow-emerald-500/5">
      <span class="relative flex h-2.5 w-2.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
      </span>
      <span>{badge}</span>
    </div>

    <!-- Main Title -->
    <h1 class="font-display text-3xl sm:text-5xl md:text-6xl font-extrabold text-slate-50 tracking-tight leading-[1.15] mb-6">
      {titlePrefix}<span class="text-emerald-400">{titleHighlightSeconds}</span>{titleMiddle}<span class="bg-gradient-to-r from-emerald-400 via-teal-300 to-emerald-200 bg-clip-text text-transparent">{titleHighlightPercentage}</span>{titleSuffix}
    </h1>

    <!-- Subtitle -->
    <p class="text-base sm:text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed font-normal">
      {subtitle}
    </p>

    <!-- Main CTA Button -->
    <div class="flex flex-col items-center justify-center gap-4">
      <a 
        href="#cuestionario" 
        class="inline-flex items-center justify-center gap-3 px-8 py-4 rounded-2xl bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-bold text-lg sm:text-xl shadow-lg shadow-emerald-500/25 transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] btn-glow group"
      >
        <span>{ctaText}</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-300 group-hover:translate-y-1 stroke-[3]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5v14"/>
          <path d="m19 12-7 7-7-7"/>
        </svg>
      </a>

      <!-- Micro Trust Indicator -->
      <p class="text-xs sm:text-sm text-slate-400 font-medium flex items-center justify-center flex-wrap gap-2 mt-2">
        {trustBadges.map((badge, idx) => (
          <>
            <span>{badge}</span>
            {idx < trustBadges.length - 1 && <span class="text-slate-600">•</span>}
          </>
        ))}
      </p>
    </div>
  </div>
</section>
